# === Notion CRM (required for sync) ===
NOTION_API_KEY=secret_xxx
NOTION_DATABASE_ID=your_notion_database_id

# === Apify (required for 4 scrapers: YC, Built In, WTTJ, TrueUp) ===
APIFY_API_KEY=apify_api_xxx

# === LLM (optional — falls back to keyword classifier) ===
ANTHROPIC_API_KEY=sk-ant-xxx

# === Email Enrichment (optional — falls back to manual) ===
HUNTER_API_KEY=xxx

# === Chrome Profile (for Playwright scrapers) ===
CHROME_USER_DATA_DIR=/Users/you/Library/Application Support/Google/Chrome

# === Dashboard ===
DASHBOARD_THEME=light
